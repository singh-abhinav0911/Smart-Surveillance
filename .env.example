# .env.example — commit this
# .env — never commit (add to .gitignore)

# ── App ───────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=surveillance_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_MIN_CONN=5
DB_MAX_CONN=20

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Model ─────────────────────────────────────────────
MODEL_PATH=models/yolov8n.pt
MODEL_CONF=0.5
MODEL_IMGSZ=640
INFERENCE_EVERY_N=3

# ── Speed ─────────────────────────────────────────────
SPEED_LIMIT_KMH=60
PIXELS_PER_METER=10
LINE_Y=360

# ── Cameras (comma separated) ─────────────────────────
# CAMERA_SOURCES=gate_1:0,gate_2:rtsp://192.168.1.1/stream
CAMERA_SOURCES=gate_1:0